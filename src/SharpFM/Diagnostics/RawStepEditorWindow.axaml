<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    x:Class="SharpFM.Diagnostics.RawStepEditorWindow"
    Title="Edit Step XML"
    Width="720"
    Height="520"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto">

        <TextBlock Grid.Row="0" Classes="Fluent2Body" Margin="0,0,0,8"
                   Text="Edit the raw XML for this step. Your edit replaces the sealed step's stored XML on Save. Cancel discards changes." />

        <Border Grid.Row="1" Classes="Fluent2SurfaceElevated">
            <AvaloniaEdit:TextEditor
                x:Name="xmlEditor"
                FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                ShowLineNumbers="True"
                SyntaxHighlighting="Xml"
                WordWrap="False" />
        </Border>

        <TextBlock Grid.Row="2" x:Name="statusLabel" Classes="Fluent2Caption"
                   Margin="0,8,0,0" Foreground="#C08000" Text="" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,12,0,0">
            <Button x:Name="cancelButton" Classes="Fluent2" Content="Cancel" />
            <Button x:Name="saveButton" Classes="Fluent2Primary" Content="Save" />
        </StackPanel>

    </Grid>

</Window>
